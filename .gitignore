# ⚠️ API Keys — NEVER expose these
.env

# Data files — raw and derived artifacts are regenerated via the pipeline,
# but the processed dataset CSV is kept in version control.
data/raw/
data/processed/model_ready/
# data/processed/trained_models/
data/splits/

# Saved models — regenerate via training scripts
# models/saved/

# Python cache
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# Jupyter checkpoints
.ipynb_checkpoints/
*.ipynb_checkpoints

# Virtual environment
venv/
env/
.venv/

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
